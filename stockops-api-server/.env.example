# StockOps API Environment Variables
# Copy to .env and fill in real values, or use external secret manager

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=stockops
DB_USER=stockops
DB_PASSWORD=your_password_here

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRATION=86400000

# Server
SERVER_PORT=8080

# AI (optional)
AI_MAX_TOKENS=1024

# Logging
LOG_LEVEL=INFO
