aws_region  = "ap-northeast-2"
project     = "stockops"
environment = "dev"

# Leave empty to automatically select the most recent EB AL2023 Docker platform.
eb_solution_stack_name = ""

# Leave empty to use the ECR repositories created by this Terraform.
# After the first apply, push images to the output repository URLs with the :dev tag.
api_image_uri      = ""
sensimul_image_uri = ""

# Keep empty to generate a random secret.
jwt_secret = ""

# Dev web origins allowed by API CORS.
admin_allowed_origin  = "https://admindev.ithans.com"
client_allowed_origin = "https://clientdev.ithans.com"

create_rds           = true
db_name              = "stockops"
db_username          = "stockops"
db_instance_class    = "db.t4g.micro"
db_allocated_storage = 20

# Leave empty to let AWS choose the default supported PostgreSQL minor version.
db_engine_version = ""

enable_admin_cloudfront  = true
enable_client_cloudfront = false

enable_mqtt       = true
mqtt_desired_count = 1

# Keep 0 until the Sensimul image is pushed and config is ready.
sensimul_desired_count = 0

stockops_analytics_enabled = false
stockops_ai_enabled        = false

spring_mail_host = "localhost"
spring_mail_port = "25"
